generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  PRODUCT_MANAGER
  DEVELOPER
  MARKETING
  HR
  QA
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum BlockerSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BlockerType {
  TECHNICAL
  REQUIREMENT
  DEPENDENCY
  INFRASTRUCTURE
  COMMUNICATION
  TESTING
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  IN_TESTING
  DONE
  CANCELED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELED
}

enum NotificationType {
  MENTION
  ASSIGNED
  STATUS_CHANGE
  SPRINT_STARTED
  SPRINT_ENDED
  BLOCKER_ALERT
  SYSTEM
}

enum FeedbackCategory {
  SPRINT
  TASK_ASSIGNMENT
  DEADLINE
  COMMUNICATION
  TEAM_COLLABORATION
  PROCESS_IMPROVEMENT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       UserRole
  department String
  avatar     String?
  isActive   Boolean  @default(true)

  projectsOwned        Project[]               @relation("ProjectOwner")
  tasksAssigned        Task[]                  @relation("TaskAssignee")
  tasksCreated         Task[]                  @relation("TaskCreator")
  comments             Comment[]
  commentReactions     CommentReaction[]
  inAppNotifications   InAppNotification[]
  activities           TaskActivity[]
  enterpriseActivities ActivityLog[]
  standups             DailyStandup[]
  blockersReported     Blocker[]
  feedbacks            Feedback[]
  notifications        Notification[]
  performanceMetrics   TeamPerformanceMetric[]

  projectMembers ProjectMember[]
  sprintMembers  SprintMember[]
  blockersHelped Blocker[]       @relation("BlockerHelper")
  focuses        TodayFocus[]
  sessions       UserSession[]

  chatMessages        ChatMessage[]
  messageReactions    MessageReaction[]
  chatMemberships     ChatMember[]
  pinnedMessages      PinnedMessage[]
  createdChannels     ChatChannel[]           @relation("CreatedChannels")
  timesheets          Timesheet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Project {
  id          String        @id @default(uuid())
  key         String        @unique // e.g., "PROJ"
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  deadline    DateTime?
  ownerId     String

  owner User @relation("ProjectOwner", fields: [ownerId], references: [id])

  sprints       Sprint[]
  tasks         Task[]
  members       ProjectMember[]
  sprintReports SprintReport[]
  chatChannels  ChatChannel[]

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ProjectMember {
  id        String @id @default(uuid())
  projectId String
  userId    String
  role      String @default("MEMBER") // e.g. LEAD, MEMBER

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Sprint {
  id        String       @id @default(uuid())
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  status    SprintStatus @default(PLANNED)
  projectId String

  project            Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks              Task[]
  standups           DailyStandup[]
  feedbacks          Feedback[]
  retrospectives     RetrospectiveComparison[]
  report             SprintReport?
  performanceMetrics TeamPerformanceMetric[]
  members            SprintMember[]
  chatChannels       ChatChannel[]

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model SprintMember {
  id       String @id @default(uuid())
  sprintId String
  userId   String

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sprintId, userId])
}

model Task {
  id                 String       @id @default(uuid())
  key                String       @unique // e.g., "PROJ-123"
  title              String
  description        String?
  type               String       @default("STORY") // STORY, BUG, TASK, EPIC
  status             TaskStatus   @default(TODO)
  priority           TaskPriority @default(MEDIUM)
  storyPoints        Int?
  dueDate            DateTime?
  startDate          DateTime?
  acceptanceCriteria String?
  labels             String[]

  projectId  String
  sprintId   String?
  assigneeId String?
  creatorId  String

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint   Sprint? @relation(fields: [sprintId], references: [id])
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User    @relation("TaskCreator", fields: [creatorId], references: [id])

  comments    Comment[]
  activities  TaskActivity[]
  attachments Attachment[]
  blockers    Blocker[]
  subtasks    TaskSubtask[]
  standups    DailyStandup[]
  chatChannels ChatChannel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isArchived    Boolean   @default(false)
  archivedAt    DateTime?
  archivedById  String?
  completedAt   DateTime?
  completedById String?

  @@index([projectId])
  @@index([assigneeId])
  @@index([sprintId])
}

model Comment {
  id               String   @id @default(uuid())
  taskId           String
  userId           String
  parentCommentId  String?
  content          String
  isEdited         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment    Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies          Comment[] @relation("CommentReplies")
  reactions        CommentReaction[]
}

model CommentReaction {
  id               String   @id @default(uuid())
  commentId        String
  userId           String
  emoji            String

  comment          Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
}

model TaskSubtask {
  id          String  @id @default(uuid())
  title       String
  isCompleted Boolean @default(false)
  taskId      String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskActivity {
  id       String  @id @default(uuid())
  taskId   String
  userId   String
  action   String // e.g., "STATUS_CHANGED", "ASSIGNEE_CHANGED"
  oldValue String?
  newValue String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model DailyStandup {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  yesterday String
  today     String
  blockers  String?
  userId    String
  sprintId  String
  taskId    String?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sprint           Sprint    @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  task             Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reportedBlockers Blocker[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, sprintId, date])
}

model Blocker {
  id          String  @id @default(uuid())
  description String
  isResolved  Boolean @default(false)

  severity                BlockerSeverity @default(HIGH)
  type                    BlockerType     @default(TECHNICAL)
  estimatedResolutionDate DateTime?
  helperId                String?

  taskId     String
  reporterId String
  standupId  String?

  task     Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reporter User          @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  helper   User?         @relation("BlockerHelper", fields: [helperId], references: [id])
  standup  DailyStandup? @relation(fields: [standupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resolvedAt     DateTime?
  resolvedById   String?
  resolutionNote String?
  chatChannels   ChatChannel[]
}

model Feedback {
  id        String           @id @default(uuid())
  content   String
  sentiment String? // POSITIVE, NEUTRAL, NEGATIVE
  category  FeedbackCategory @default(SPRINT)

  // Specific questions
  wentWell            String?
  wentWrong           String?
  improvement         String?
  realisticPlanning   Boolean @default(true)
  achievableDeadlines Boolean @default(true)
  fairDistribution    Boolean @default(true)
  blockerPatterns     String?

  userId   String
  sprintId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SprintReport {
  id             String  @id @default(uuid())
  sprintId       String  @unique
  projectId      String
  successRate    Float
  velocity       Int
  completedTasks Int
  pendingTasks   Int
  blockerCount   Int
  summary        String?

  sprint  Sprint  @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model TeamPerformanceMetric {
  id                 String @id @default(uuid())
  userId             String
  sprintId           String
  assignedTasks      Int
  completedTasks     Int
  delayedTasks       Int
  blockersRaised     Int
  avgCompletionTime  Float // in hours
  standupConsistency Float // percentage
  utilizationRate    Float // percentage

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, sprintId])
}

model AnalyticsSnapshot {
  id                   String   @id @default(uuid())
  date                 DateTime @default(now())
  totalActiveTasks     Int
  sprintCompletionRate Float
  delayedTasks         Int
  blockersCount        Int
  teamVelocity         Int
  avgCompletionTime    Float
  activeProjects       Int
  teamUtilization      Float
}

model RetrospectiveComparison {
  id       String @id @default(uuid())
  metrics  Json // Stores sprint velocity, completed points, etc.
  sprintId String

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Notification {
  id      String           @id @default(uuid())
  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)
  linkUrl String?
  userId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Attachment {
  id       String @id @default(uuid())
  fileName String
  fileUrl  String
  fileType String
  fileSize Int
  taskId   String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(uuid())

  userId     String
  action     String // e.g., "CREATED", "UPDATED", "DELETED"
  entityType String // e.g., "PROJECT", "USER"
  entityId   String
  metadata   Json?

  createdAt DateTime @default(now())
}

model MemberSprintStats {
  id             String @id @default(uuid())
  userId         String
  sprintId       String
  completedTasks Int
  pendingTasks   Int
  storyPoints    Int
  completionRate Float
  blockerCount   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TodayFocus {
  id      String @id @default(uuid())
  userId  String
  content String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ProductivitySnapshot {
  id String @id @default(uuid())

  userId String

  completedTasks    Int
  pendingTasks      Int
  blockers          Int
  productivityScore Float

  createdAt DateTime @default(now())
}

model EmailLog {
  id           String   @id @default(uuid())
  taskId       String?
  recipient    String
  subject      String
  status       String
  provider     String
  errorMessage String?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  actionType  String
  entityType  String
  entityId    String
  title       String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model NotificationHistory {
  id             String   @id @default(uuid())
  type           String
  title          String
  description    String
  senderId       String
  receiverId     String?
  taskId         String?
  sprintId       String?
  projectId      String?
  mailSent       Boolean  @default(false)
  deliveryStatus String
  createdAt      DateTime @default(now())
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  deviceName       String?
  isActive         Boolean  @default(true)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model SecurityAuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  severity  String
  createdAt DateTime @default(now())
}

model LoginHistory {
  id            String    @id @default(uuid())
  userId        String?
  email         String
  ipAddress     String?
  userAgent     String?
  deviceName    String?
  status        String
  failureReason String?
  loggedInAt    DateTime  @default(now())
  loggedOutAt   DateTime?
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model InAppNotification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  type        String
  isRead      Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatChannel {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String // DIRECT, PROJECT, SPRINT, TASK, BLOCKER, ANNOUNCEMENT
  projectId   String?
  sprintId    String?
  taskId      String?
  blockerId   String?
  createdById String
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  createdBy User     @relation("CreatedChannels", fields: [createdById], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint    Sprint?  @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  blocker   Blocker? @relation(fields: [blockerId], references: [id], onDelete: Cascade)

  messages  ChatMessage[]
  members   ChatMember[]
  pinnedMessages PinnedMessage[]
}

model ChatMessage {
  id              String   @id @default(uuid())
  channelId       String
  senderId        String
  content         String
  messageType     String // TEXT, SYSTEM, TASK_REFERENCE
  parentMessageId String?
  isEdited        Boolean  @default(false)
  editedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  channel       ChatChannel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender        User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  parentMessage ChatMessage?   @relation("ThreadReplies", fields: [parentMessageId], references: [id], onDelete: Cascade)
  replies       ChatMessage[]  @relation("ThreadReplies")
  reactions     MessageReaction[]
  pinnedMessage PinnedMessage?
}

model MessageReaction {
  id        String @id @default(uuid())
  messageId String
  userId    String
  emoji     String

  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model ChatMember {
  id         String    @id @default(uuid())
  channelId  String
  userId     String
  joinedAt   DateTime  @default(now())
  lastSeenAt DateTime?

  channel    ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model PinnedMessage {
  id         String   @id @default(uuid())
  channelId  String
  messageId  String   @unique
  pinnedById String
  createdAt  DateTime @default(now())

  channel    ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy   User        @relation(fields: [pinnedById], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
}

model Timesheet {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @default(now()) // The day the timesheet is for
  tasksWorkedOn String   // Summary of what was done
  hoursWorked   Float    // Number of hours worked
  notes         String?  // Optional notes

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([date])
}
