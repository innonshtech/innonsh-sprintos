{
  "version": 2,
  "regions": ["bom1"],
  "builds": [
    {
      "src": "src/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/remind-timesheets",
      "schedule": "15 12 * * 1-5"
    }
  ]
}
